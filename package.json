{
  "name": "horizon-mcp",
  "version": "1.2.0",
  "description": "MCP server for horizOn Backend-as-a-Service — documentation, live API tools, and workflow prompts for Godot, Unity, and Unreal Engine integration.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "horizon-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src/resources/**/*.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "horizon",
    "baas",
    "gamedev",
    "godot",
    "unity",
    "unreal",
    "backend-as-a-service",
    "model-context-protocol"
  ],
  "author": "ProjectMakers <contact@projectmakers.de> (https://projectmakers.de)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProjectMakersDE/horizOn-mcp.git"
  },
  "homepage": "https://www.npmjs.com/package/horizon-mcp",
  "bugs": {
    "url": "https://github.com/ProjectMakersDE/horizOn-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
